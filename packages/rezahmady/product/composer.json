            "Rezahmady\\Product\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rezahmady\\Product\\AddonServiceProvider"
            ]
        }
    }
