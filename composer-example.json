{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0",
        "backpack/backupmanager": "^4.0",
        "backpack/crud": "^5.0",
        "backpack/filemanager": "^2.0",
        "backpack/logmanager": "^4.0",
        "backpack/pro": "dev-master",
        "backpack/revise-operation": "^1.0",
        "backpack/settings": "^3.0",
        "beyondcode/laravel-websockets": "^2.0",
        "codedge/laravel-selfupdater": "^3.4",
        "cviebrock/eloquent-sluggable": "^9.0",
        "eskandari/persianrender": "^0.1.0",
        "fabpot/goutte": "^4.0",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.4",
        "hekmatinasser/verta": "^2.1",
        "javoscript/laravel-macroable-models": "^1.0",
        "kdabrow/seeder-once": "^2.2",
        "laravel/framework": "^9.2",
        "livewire/livewire": "^2.3",
        "nwidart/laravel-modules": "^9.0",
        "rezahmady/setting-operation": "^1.0",
        "spatie/laravel-permission": "^5.0",
        "spatie/laravel-sitemap": "^6.0",
        "staudenmeir/eloquent-json-relations": "^1.5",
        "tormjens/eventy": "^0.8.0"
    },
    "require-dev": {
        "backpack/generators": "^3.1",
        "barryvdh/laravel-ide-helper": "^2.9",
        "spatie/laravel-ignition": "^1.0",
        "fakerphp/faker": "^1.9.1",
        "laracasts/generators": "^2.0",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.3.3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "core/"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-ide-helper"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan vendor:publish --force --tag=livewire:assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
